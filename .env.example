# Formspree endpoint for the Revenue Leakage Analysis intake form.
# Create a form at https://formspree.io, copy the endpoint URL, and set this in Vercel env vars.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Formspree endpoint for the general Contact form (can be the same as above or a separate form).
NEXT_PUBLIC_FORMSPREE_CONTACT_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
